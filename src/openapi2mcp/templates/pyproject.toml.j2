[build-system]
requires = ["setuptools>=68"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ server_name }}"
version = "0.1.0"
description = "MCP server generated by openapi2mcp"
requires-python = ">=3.10"
dependencies = ["mcp>=1.0", "httpx>=0.27", "starlette>=0.37", "uvicorn>=0.29"]

[tool.setuptools]
py-modules = ["server", "tools", "executor"]
